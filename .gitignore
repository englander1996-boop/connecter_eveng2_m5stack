# ============================================================
#  機密情報（絶対にコミットしない）
# ============================================================
# Wi-Fi の SSID / パスワードなど。テンプレートの secrets.h.example だけ追跡する。
firmware/**/secrets.h

# ============================================================
#  PlatformIO（firmware）
# ============================================================
.pio/
.pioenvs/
.piolibdeps/

# ============================================================
#  Node.js / Vite（app）
# ============================================================
node_modules/
dist/
.vite/
*.tsbuildinfo

# npm / yarn / pnpm のデバッグログ
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ============================================================
#  ビルド成果物
# ============================================================
# EvenHub パッケージ（ehpk）はビルドで再生成される
*.ehpk

# ============================================================
#  エディタ / OS
# ============================================================
.vscode/
!.vscode/extensions.json
.idea/
*.swp
*.swo

# Windows
Thumbs.db
Desktop.ini
$RECYCLE.BIN/

# macOS
.DS_Store

# ============================================================
#  Claude Code（個人設定のみ無視。プロジェクト共有設定は残す）
# ============================================================
.claude/settings.local.json
